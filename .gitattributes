# Auto detect text files and perform LF normalization
* text=auto

# Normalize all text files
*.txt text
*.md text
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.css text
*.scss text
*.html text
*.xml text
*.yml text
*.yaml text

# Explicitly declare text files you want to always normalize
*.xml text eol=lf
*.txt text eol=lf
robots.txt text eol=lf
sitemap.xml text eol=lf

# Declare files that should always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (should not be modified)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Force LF for specific directories
scripts/**/*.js text eol=lf
scripts/**/*.txt text eol=lf
scripts/**/*.xml text eol=lf
public/**/*.txt text eol=lf
public/**/*.xml text eol=lf