    },
    {
      "source": "/services/ecommerce",
      "destination": "/ecommerce-website-development-in-faridabad",
      "permanent": true
    },
    {
      "source": "/services/annual-maintenance",
      "destination": "/website-maintenance-services-in-faridabad",
