      "destination": "/digital-marketing-company-in-faridabad",
      "permanent": true
    },
    {
      "source": "/blog/why-local-businesses-need-a-website-in-2026",
      "destination": "/blog/why-small-businesses-need-a-website",
      "permanent": true
    },
    {
      "source": "/services/website-design",
