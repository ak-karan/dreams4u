{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/about",
      "destination": "/about-dreams4u",
      "permanent": true
    },
    {
      "source": "/digital-marketing-services-in-faridabad",
      "destination": "/digital-marketing-company-in-faridabad",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
