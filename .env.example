# Google Places API Configuration
# Get your API key from: https://console.cloud.google.com/
# Enable Places API for your project
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Get your Place ID from: https://developers.google.com/maps/documentation/places/web-service/details#find_place
# Search for your business on Google Maps and find the Place ID
VITE_GOOGLE_PLACE_ID=your_google_place_id_here
